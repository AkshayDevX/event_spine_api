# Server Configuration
PORT=7000
NODE_ENV=development
LOG_LEVEL=debug

# Auth Configuration
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Database Configuration (PostgreSQL)
POSTGRES_USER=event_spine_user
POSTGRES_PASSWORD=event_spine_password
POSTGRES_DB=event_spine_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://event_spine_user:event_spine_password@localhost:5432/event_spine_db

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# PM2 Process Scaling
PM2_INSTANCES=max
PM2_WORKER_INSTANCES=1

# Webhook Ingress Resilience
WEBHOOK_RATE_LIMIT_MAX=100
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
IDEMPOTENCY_TTL_SECONDS=86400

# Outbound Step Resilience
HTTP_CIRCUIT_FAILURE_THRESHOLD=5
HTTP_CIRCUIT_RESET_TIMEOUT_MS=30000
